# Monte Carlo routines


def rainbow_option_monte_carlo(S1, S2, S3, S4, horizon_T, n_simulation=n_sim, n_steps=n_st, seed=None):
    """
    Single-run Monte Carlo estimator for a call on max(S1..S4).
    horizon_T: time-to-maturity (tau)
    Returns: (mc_price, SE_classical, call_payoffs_array)
    """
    if seed is not None:
        np.random.seed(seed)

    dt = float(horizon_T) / n_steps
    call = np.zeros(int(n_simulation), dtype=float)

    cov_matrix = np.array([
        [1, rho12, rho13, rho14],
        [rho12, 1, rho23, rho24],
        [rho13, rho23, 1, rho34],
        [rho14, rho24, rho34, 1]
    ])
    L = np.linalg.cholesky(cov_matrix)

    for j in range(int(n_simulation)):
        s = np.array([S1, S2, S3, S4], dtype=float)
        for _ in range(int(n_steps)):
            z = np.random.normal(size=4)
            e2 = L.dot(z)
            drift = (r - 0.5 * np.array([sigma1, sigma2, sigma3, sigma4])**2) * dt
            diffusion = np.array([sigma1, sigma2, sigma3, sigma4]) * e2 * np.sqrt(dt)
            s *= np.exp(drift + diffusion)
        payoff = max(np.max(s) - K, 0.0)   # call on max
        call[j] = payoff

    mc_price = np.mean(call) * np.exp(-r * horizon_T)
    return mc_price

def rainbow_option_monte_carlo_replications(S1, S2, S3, S4, T, seed=None):
    """
    Monte Carlo with multiple replications for standard error calculation.
    Returns:
        mc_means: mean of MC replications
        mc_std_errors: standard error across replications
        mc_all: array of shape (n_replications,) with individual replication means
    """
    n_replications=n_rep
    n_simulation=n_sim
    n_steps=n_st

    if seed is not None:
        np.random.seed(seed)

    mc_all = np.zeros(n_replications, dtype=float)

    for k in range(n_replications):
        dt = T / n_steps
        cov_matrix = np.array([
            [1, rho12, rho13, rho14],
            [rho12, 1, rho23, rho24],
            [rho13, rho23, 1, rho34],
            [rho14, rho24, rho34, 1]
        ])
        L = np.linalg.cholesky(cov_matrix)

        payoffs = np.zeros(n_simulation)
        for j in range(n_simulation):
            s = np.array([S1, S2, S3, S4], dtype=float)
            for _ in range(n_steps):
                z = np.random.normal(size=4)
                e2 = L.dot(z)
                s = s * np.exp((r - 0.5 * np.array([sigma1, sigma2, sigma3, sigma4])**2) * dt
                               + np.array([sigma1, sigma2, sigma3, sigma4]) * e2 * np.sqrt(dt))
            payoff = max(s) - K
            payoffs[j] = max(payoff, 0.0)
        mc_all[k] = np.mean(payoffs) * np.exp(-r * T)

    mc_mean = mc_all.mean()
    mc_std_error = mc_all.std(ddof=1) /np.sqrt(n_replication) # se across replications
    return mc_mean, mc_std_error, mc_all


# Modified 1D Black-Scholes
def bs_call_1d(S, tau, sigma):
    S = np.maximum(S, 1e-8)
    tau = np.maximum(tau, 1e-8)

    d1 = (np.log(S / K) + (r + 0.5 * sigma**2) * tau) / (sigma * np.sqrt(tau))
    d2 = d1 - sigma * np.sqrt(tau)

    return S * si.norm.cdf(d1) - K * np.exp(-r * tau) * si.norm.cdf(d2)



