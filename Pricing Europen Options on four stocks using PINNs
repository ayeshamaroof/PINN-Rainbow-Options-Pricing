# PINN

def pde(x, y):
    x1, x2, x3, x4, t = x[:, 0:1], x[:, 1:2], x[:, 2:3], x[:, 3:4], x[:, 4:5]

    # First derivatives
    dy_x1 = dde.grad.jacobian(y, x, i=0, j=0)
    dy_x2 = dde.grad.jacobian(y, x, i=0, j=1)
    dy_x3 = dde.grad.jacobian(y, x, i=0, j=2)
    dy_x4 = dde.grad.jacobian(y, x, i=0, j=3)

    # Time derivative
    dy_t = dde.grad.jacobian(y, x, i=0, j=4)

    # Second derivatives (diagonal)
    V_xx = (
        sigma1**2 * x1**2 * dde.grad.hessian(y, x, i=0, j=0)
      + sigma2**2 * x2**2 * dde.grad.hessian(y, x, i=1, j=1)
      + sigma3**2 * x3**2 * dde.grad.hessian(y, x, i=2, j=2)
      + sigma4**2 * x4**2 * dde.grad.hessian(y, x, i=3, j=3)
    )

    # Mixed derivatives
    V_xy = (
        2 * sigma1*sigma2*rho12*x1*x2 * dde.grad.hessian(y, x, i=0, j=1)
      + 2 * sigma1*sigma3*rho13*x1*x3 * dde.grad.hessian(y, x, i=0, j=2)
      + 2 * sigma1*sigma4*rho14*x1*x4 * dde.grad.hessian(y, x, i=0, j=3)
      + 2 * sigma2*sigma3*rho23*x2*x3 * dde.grad.hessian(y, x, i=1, j=2)
      + 2 * sigma2*sigma4*rho24*x2*x4 * dde.grad.hessian(y, x, i=1, j=3)
      + 2 * sigma3*sigma4*rho34*x3*x4 * dde.grad.hessian(y, x, i=2, j=3)
    )

    diffusion = 0.5 * (V_xx + V_xy)

    drift = r * (x1*dy_x1 + x2*dy_x2 + x3*dy_x3 + x4*dy_x4)

    return dy_t - diffusion - drift + r*y

def func_payoff_numpy(x):
    # convert to TF to use softmax then back, or compute directly in numpy
    S = x[:, 0:4]
    tau = x[:, 4:5]
    # numerical stability: use numpy implementation of softmax row-wise
    # subtract row-wise max
    row_max = np.max(S / tau_sm, axis=1, keepdims=True)
    exps = np.exp((S / tau_sm) - row_max)
    weights = exps / np.sum(exps, axis=1, keepdims=True)
    smooth_max = np.sum(weights * S, axis=1, keepdims=True)
    payoff = np.maximum(smooth_max - K, 0.0)
    return payoff

def asymptotic_max(x):
    S = x[:, 0:4]
    tau = x[:, 4:5]
    row_max = np.max(S / tau_sm, axis=1, keepdims=True)
    exps = np.exp((S / tau_sm) - row_max)
    weights = exps / np.sum(exps, axis=1, keepdims=True)
    maxS = np.sum(weights * S, axis=1, keepdims=True)
    return maxS - K * np.exp(-r * tau)


def main():


    # Geometry and time domain: tau in [0, T_final]
    b = stock_max
    xmin = [0.0, 0.0, 0.0, 0.0]
    xmax = [b, b, b, b]
    geom = dde.geometry.geometry_nd.Hypercube(xmin=xmin, xmax=xmax)
    timedomain = dde.geometry.TimeDomain(0.0, T_final)  # tau in [0, T_final]
    geomtime = dde.geometry.GeometryXTime(geom, timedomain)

     # -------------------------
     # ZERO boundary condition: S1=S2=S3=S4=0
     # -------------------------
    N_z = 20
    tau_zero = np.random.uniform(0.0, T_final, N_z)

    X_zero = np.column_stack([
         np.zeros(N_z),
         np.zeros(N_z),
         np.zeros(N_z),
         np.zeros(N_z),
         tau_zero
     ])

    y_zero = np.zeros((N_z, 1))

    bc_zero = dde.icbc.PointSetBC(X_zero, y_zero)

    # IC at tau=0 (i.e., time-to-maturity = 0) is payoff at expiry; that's func_payoff_numpy with tau=0
    bc_ic = dde.icbc.IC(geomtime, func_payoff_numpy, lambda _, on_initial: on_initial)

    #max boundry
    # drichlet fixed tried neuman didnt improve
    bc_S1_max = dde.DirichletBC(geomtime, asymptotic_max, lambda x, on_boundary: on_boundary and np.isclose(x[0], b))
    bc_S2_max = dde.DirichletBC(geomtime, asymptotic_max, lambda x, on_boundary: on_boundary and np.isclose(x[1], b))
    bc_S3_max = dde.DirichletBC(geomtime, asymptotic_max, lambda x, on_boundary: on_boundary and np.isclose(x[2], b))
    bc_S4_max = dde.DirichletBC(geomtime, asymptotic_max, lambda x, on_boundary: on_boundary and np.isclose(x[3], b))

    # ONE-STOCK-NONZERO BCs (1D BS faces)
    N_face = 50
    eps = 0.0001
    sigmas = [sigma1, sigma2, sigma3, sigma4]

    bs_face_bcs = []

    for d in range(4):  # active stock index
        S_active = np.random.uniform(0.01, b, N_face)
        tau = np.random.uniform(1e-4, T_final, N_face)

        X_face = np.column_stack([
            S_active if d == 0 else np.full(N_face, eps),
            S_active if d == 1 else np.full(N_face, eps),
            S_active if d == 2 else np.full(N_face, eps),
            S_active if d == 3 else np.full(N_face, eps),
            tau
        ])

        # Pass the correct sigma for the active stock
        y_face = bs_call_1d(S_active, tau, sigma=sigmas[d]).reshape(-1, 1)

        bs_face_bcs.append(dde.icbc.PointSetBC(X_face, y_face))

    # Deep OTM enforcement 
    N_otm = 10*col  # number of OTM points; can tune
    X_otm = np.random.uniform(0.0, K * 0.5, (N_otm, 4))  # S1..S4 < 0.5*K
    tau_otm = np.random.uniform(0.0, T_final, N_otm)
    X_otm = np.column_stack([X_otm, tau_otm])
    y_otm = np.zeros((N_otm, 1))
    bc_otm = dde.icbc.PointSetBC(X_otm, y_otm)

    bcs = [bc_ic, bc_zero, bc_otm,
        bc_S1_max, bc_S2_max, bc_S3_max, bc_S4_max]+ bs_face_bcs #+ bc_2d_faces+bc_3d_faces

    # Oversampled deep OTM interior points (anchors)
    N_otm_domain = 20*col  # number of extra domain points
    S_otm_domain = np.random.uniform(0.0, 0.8*K, (N_otm_domain, 4))
    tau_otm_domain = np.random.uniform(0.0, T_final, N_otm_domain)
    X_otm_domain = np.column_stack([S_otm_domain, tau_otm_domain])


    # Oversampled deep ITM interior points (anchors)
    N_itm_domain = 20*col  # number of extra domain points
    S_itm_domain = np.random.uniform(1.5*K, b*K, (N_itm_domain, 4))  # well above strike
    tau_itm_domain = np.random.uniform(0.0, T_final, N_itm_domain)
    X_itm_domain = np.column_stack([S_itm_domain, tau_itm_domain])


    # Oversampled ATM interior points (anchors)
    N_atm_domain = 20*col  # number of extra domain points
    S_atm_domain = np.random.normal(0.9*K, 1.1*K, (N_atm_domain, 4))  # atmoney
    tau_atm_domain = np.random.uniform(0.0, T_final, N_atm_domain)
    X_atm_domain = np.column_stack([S_atm_domain, tau_atm_domain])


    X_extra = np.vstack([X_otm_domain, X_itm_domain,X_atm_domain])

    data = dde.data.TimePDE(
        geomtime, pde, bcs,
        num_domain=2000 * col,
        num_initial=200 * col,
        num_boundary=100 * col,
        anchors=X_extra ) # combine OTM and ITM oversampled points


    # Network: moderately larger to capture complexity
    net = dde.nn.FNN([5] + [30] *3+ [1], "tanh", "Glorot uniform")
    net.apply_output_transform(lambda x, y: tf.nn.softplus(y))
    model = dde.Model(data, net)

    lenbc=len(bcs)-1
    model.compile("adam", lr=1e-4,loss_weights=[1,5]+[1]*lenbc)
    model.train(epochs=10000, display_every=1500)
    model.compile("L-BFGS",loss_weights=[1,5]+[1]*lenbc)
    losshistory, train_state = model.train()

    dde.saveplot(losshistory, train_state, issave=True, isplot=True)

########################################################
#EVALUATION
####################################
    np.random.seed(42)
    b2=eval_stock_max
    S1s = np.random.uniform(0.01, b2, N_test)
    S2s = np.random.uniform(0.01, b2, N_test)
    S3s = np.random.uniform(0.01, b2, N_test)
    S4s = np.random.uniform(0.01, b2, N_test)
    taus = np.random.uniform(0.0, T_final, N_test)  # time-to-maturity

    X= np.column_stack((S1s, S2s, S3s, S4s, taus))

    y_true = np.zeros((N_test))


    # Obtain the value of the MC solution for evaluation for each generated point:
    for i in range(N_test):
        S1, S2, S3, S4, t = X[i]
        y_true[i] = rainbow_option_monte_carlo(S1, S2, S3, S4, t)
        if (i + 1) % 20 == 0:
            print(f"Completed {i + 1} runs")


    y_pred = model.predict(X)
    y_pred = y_pred[:, 0]


    # unscalling for evaluation
    y_true_filtered = y_true*K1
    y_pred_filtered = y_pred*K1

    print("##########################")


    mse =dde.metrics.mean_squared_error(y_true_filtered, y_pred_filtered)
    print("MSE:", mse)
    print("rmse=",np.sqrt(mse))
    e=dde.metrics.mean_absolute_percentage_error(y_true_filtered, y_pred_filtered)
    print('mean_absolute_percentage_error=',e)
    c=dde.metrics.l2_relative_error(y_true_filtered, y_pred_filtered)
    print('l2_relative_error=',c,)
    print("r2=",r2_score(y_true_filtered, y_pred_filtered))



    # Slices you want to test
    fixed_slices = [
        (0.5, 1.0, 1.5),
        (1.0, 1.0, 1.0),
        (0.5, 0.5, 0.5),
        (1.1, 1.1, 1.1),
    ]

    taus = [1.0]

    for tau in taus:
        for fs in fixed_slices:
            plot_single_stock_slice(
                model,
                fixed_S=fs,
                tau=tau
            )

if __name__ == "__main__":
    main()
