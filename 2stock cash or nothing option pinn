def plot_single_stock_slice_2d(model, fixed_S1=1.0, tau=0.5,
                               s2_min=0.05, s2_max=2.0*K,
                               n_points=20, ci=0.95):
    z = norm.ppf(0.5 + ci / 2)
    n_rep=25
    S2 = np.linspace(s2_min, s2_max, n_points)
    X = np.column_stack([
        np.full_like(S2, fixed_S1),
        S2,
        np.full_like(S2, tau)
    ])
    pinn = model.predict(X).ravel()

    mc_mean = np.zeros(n_points)
    mc_sd = np.zeros(n_points)
    for i, s2 in enumerate(S2):
        mc_mean[i], mc_sd[i], _ = mc_2d_replications(fixed_S1, s2, tau,n_rep=n_rep,n_steps=1)
    mc_se=mc_sd/np.sqrt(n_rep)
    plt.figure(figsize=(6,4))
    plt.plot(S2, pinn, lw=2, label="PINN")
    plt.errorbar(S2, mc_mean, yerr=z * mc_se, fmt=".", capsize=3,
                 label=f"MC ({int(ci*100)}% CI)")
    plt.xlabel("S2")
    plt.ylabel("Option value")
    plt.title(f"S1={fixed_S1}, τ={tau}")
    plt.legend()
    plt.grid(True)
    plt.show()

