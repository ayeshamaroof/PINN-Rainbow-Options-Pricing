def bs_digital_put_1d(S, tau, K, sigma):
    S = np.maximum(S, 1e-8)
    tau = np.maximum(tau, 1e-8)

    d2 = (np.log(S / K) + (r - 0.5 * sigma**2) * tau) / (sigma * np.sqrt(tau))
    return np.exp(-r * tau) * si.norm.cdf(-d2)


def payoff_smooth(x):
    tau_sm=0.01
    S = x[:, 0:2]      # (N,2)
    tau = x[:, 2:3]

    # sigmoid approximation of Heaviside
    ind1 = 1.0 / (1.0 + np.exp((S[:,0:1] - K1) / tau_sm))
    ind2 = 1.0 / (1.0 + np.exp((S[:,1:2] - K2) / tau_sm))
    payoff = C * ind1 * ind2

    return payoff

