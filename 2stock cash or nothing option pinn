def payoff_smooth_ic(x):

    S1 = x[:, 0:1]
    S2 = x[:, 1:2]
    tau = x[:, 2:3]
    eps = 0.1 * tau + 1e-6
    ind1 = 1.0 / (1.0 + np.exp((S1 - K1) / eps))
    ind2 = 1.0 / (1.0 + np.exp((S2 - K2) / eps))

    return C * ind1 * ind2


def pde(x, y):
    S1, S2, tau = x[:, 0:1], x[:, 1:2], x[:, 2:3]

    V_S1 = dde.grad.jacobian(y, x, i=0, j=0)
    V_S2 = dde.grad.jacobian(y, x, i=0, j=1)
    V_t  = dde.grad.jacobian(y, x, i=0, j=2)

    V_S1S1 = dde.grad.hessian(y, x, i=0, j=0)
    V_S2S2 = dde.grad.hessian(y, x, i=1, j=1)
    V_S1S2 = dde.grad.hessian(y, x, i=0, j=1)

    diffusion = 0.5 * (
        sigma1**2 * S1**2 * V_S1S1
        + sigma2**2 * S2**2 * V_S2S2
        + 2 * rho12 * sigma1 * sigma2 * S1 * S2 * V_S1S2
    )

    drift = r * (S1 * V_S1 + S2 * V_S2)
    REM=diffusion + drift - r * y

    return V_t - REM

