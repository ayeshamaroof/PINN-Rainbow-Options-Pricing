#MC for numarical comparison
#####################


def mc_2d_replications(S1, S2, tau,n_rep,n_steps):

    n_sim=100000
    seed=None
    if seed is not None:
        np.random.seed(seed)

    cov = np.array([[1.0, rho12],
                    [rho12, 1.0]])
    L = np.linalg.cholesky(cov)
    sig = np.array([sigma1, sigma2])
    mc_all = np.zeros(n_rep)

    for k in range(n_rep):
        payoffs = np.zeros(n_sim)

        for j in range(n_sim):
            s = np.array([S1, S2])
            dt = tau / n_steps

            for _ in range(n_steps):
                z = L @ np.random.randn(2)
                s *= np.exp(
                    (r - 0.5 * sig**2) * dt
                    + sig * z * np.sqrt(dt)
                )
            payoffs[j] = C if (s[0] < K1 and s[1] < K2) else 0.0
        mc_all[k] = np.mean(payoffs) * np.exp(-r * tau)
    return mc_all.mean(), mc_all.std(ddof=1), mc_all



